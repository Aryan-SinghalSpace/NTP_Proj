# Copy to apps/api/.env (git-ignored).
PORT=4000
WEB_ORIGIN=http://localhost:3000

# Runtime connection: NON-superuser app role — RLS is enforced.
DATABASE_URL=postgres://tracewell_app:tracewell_app@localhost:5432/tracewell

# Migration connection: owner role — creates tables, policies, grants.
MIGRATION_DATABASE_URL=postgres://tracewell:tracewell@localhost:5432/tracewell
