{
  "name": "tracewell",
  "version": "0.0.0",
  "private": true,
  "description": "Configurable Dynamic Traceability Platform — monorepo",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "infra:up": "docker compose -f infra/docker-compose.yml --env-file infra/.env up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml --env-file infra/.env down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4",
    "@types/node": "^20.14.10"
  }
}
